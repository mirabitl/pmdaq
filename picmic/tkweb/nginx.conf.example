# Nginx configuration example for PicoMic Web Interface
# This serves both the static web interface and proxies API calls to the FastAPI server

server {
    listen 80;
    server_name localhost picmic.example.com;

    # Serve static files (HTML, CSS, JS)
    location / {
        root /opt/pmdaq/picmic/tkweb;
        try_files $uri $uri/ /index.html;
    }

    # Proxy API calls to FastAPI backend
    location /picmic/ {
        proxy_pass http://localhost:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_request_buffering off;
    }

    # Optional: Swagger UI for API documentation
    location /docs {
        proxy_pass http://localhost:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    # Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}

# Redirect HTTP to HTTPS (optional, for production)
# server {
#     listen 80;
#     server_name picmic.example.com;
#     return 301 https://$server_name$request_uri;
# }
